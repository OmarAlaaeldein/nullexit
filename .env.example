# nullexit configuration template — copy to .env and fill in.
#   cp .env.example .env
# .env is gitignored (it holds secrets); this template documents every option
# with its shipping default. For coherent bundles, see scripts/profiles.sh.

# ─── Secrets (fill these in) ────────────────────────────────────────────────
# WARP WireGuard keys — from your Cloudflare WARP registration.
WIREGUARD_PRIVATE_KEY=<your-warp-wireguard-private-key>
WIREGUARD_PUBLIC_KEY=<your-warp-wireguard-public-key>
WIREGUARD_ADDRESSES=172.16.0.2/32
# Tailscale auth key — Admin Console › Settings › Keys › Generate auth key.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxxx
# HMAC seed for script-integrity signatures — generate with: openssl rand -hex 32
NULLEXIT_SEED=<run: openssl rand -hex 32>
# AdGuard Home UI + Tor ControlPort credentials.
ADGUARD_USER=admin
ADGUARD_PASSWORD=<choose-a-password>

# ─── Gateway core ───────────────────────────────────────────────────────────
# Rule-compiler memory profile: light (~52k) / medium (~167k) / heavy (~253k).
GATEWAY_RULE_PROFILE=medium
STOP_COLIMA_ON_EXIT=true
# PF fail-closed kill-switch. Leave true — this is the core leak guarantee.
KILL_SWITCH=true
# true only on trusted home networks (no AP isolation); false on campus/enterprise
# WPA2-Enterprise (forces DERP, avoids gvproxy SNAT poisoning).
TAILSCALE_ALLOW_LAN_P2P=false
GATEWAY_MSS=1120
GATEWAY_BYPASS_PING=false
GATEWAY_USE_EXIT_NODE=true
# Consecutive warp=off polls before auto-shutdown (6 = 30s; 3 = faster/stricter).
WARP_FAIL_THRESHOLD=6
BLOCKED_COUNTRIES="kp il"
HOST_MTU=1200
# Debug xtrace of toggle.sh to output.log (keep false for normal use).
DEBUG_TRACE=false

# ─── Tor hardening ──────────────────────────────────────────────────────────
# true = Tor must use obfs4 bridges only (never public guards).
TOR_USE_BRIDGES=false
TOR_BRIDGE_LINES_FILE=./tor-bridges.txt
TOR_EXCLUDE_EXIT_NODES={us},{gb},{fr},{de},{it},{ca},{jp},{kp},{il}

# ─── Cover traffic / dummy padding (scripts/noise.sh) — opt-in, default off ──
NOISE_ENABLED=false
NOISE_PAD_TARGET=
NOISE_PAD_PORT=9999
NOISE_PAD_RATE_KBPS=64
NOISE_PAD_PACKET_BYTES=1024
NOISE_PAD_JITTER_MS=40
# constant = always emit the target rate; topup = fill real-traffic gaps to keep
# the observed rate flat (stronger anti-correlation, no waste when already busy).
NOISE_PAD_MODE=constant
NOISE_PAD_IFACE=en0
# Optional: target as a % of LINK CAPACITY (overrides NOISE_PAD_RATE_KBPS).
NOISE_PAD_PCT=
NOISE_LINK_MBPS=100

# ─── FaceTime split-route (scripts/common.sh) — opt-in, default off ─────────
# ⚠️ true routes the Apple /16s below DIRECT on your REAL IP (not WARP) so
# FaceTime can hole-punch. A deliberate, narrow hole scoped to Apple infra.
FACETIME_SPLIT_ROUTE=false
FACETIME_DIRECT_SUBNETS="17.249.0.0/16"

# ─── LAN Pi-hole mode (scripts/pihole-mode.sh) — opt-in, default off ────────
# Serve AdGuard DNS filtering to non-Tailscale LAN devices (trusted networks only).
PIHOLE_LAN_MODE=false
PIHOLE_LAN_LISTEN=

# ─── Sweep throughput check (scripts/sweep.sh, check 7/7) — all optional ────
# Uncomment to override the defaults baked into sweep.sh (a fast CDN, 30s cap).
# SWEEP_THROUGHPUT_URL=https://ash-speed.hetzner.com/100MB.bin
# SWEEP_THROUGHPUT_TIMEOUT=30
# SWEEP_SKIP_THROUGHPUT=false
