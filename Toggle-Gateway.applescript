tell application "Finder" to set scriptDir to POSIX path of (container of (path to me) as alias)
tell application "Terminal"
	activate
	do script "export PATH=\"/opt/homebrew/bin:/usr/local/bin:$PATH\"; cd " & quoted form of scriptDir & "; clear; echo \"Checking Gateway Status...\"; if docker compose ps --status running | grep -q 'warp'; then echo -e \"\\nGateway is RUNNING. Stopping it now...\"; docker compose down; echo -e \"\\nRestoring normal internet (1.1.1.1). You may be prompted for your Mac password.\"; sudo networksetup -setdnsservers Wi-Fi 1.1.1.1 2>/dev/null || true; echo -e \"\\nGateway has been STOPPED.\"; else echo -e \"\\nGateway is STOPPED. Starting it now...\"; colima status >/dev/null 2>&1 || colima start --memory 0.8; if [ -f \"adguard/conf/AdGuardHome.yaml\" ] && [ ! -s \"adguard/conf/AdGuardHome.yaml\" ]; then rm -f \"adguard/conf/AdGuardHome.yaml\"; echo \"Removed corrupted empty AdGuardHome.yaml to prevent crash loop.\"; fi; docker compose up -d; echo -e \"\\nEnsuring Mac is connected to Tailscale mesh...\"; if command -v tailscale >/dev/null 2>&1; then if ! tailscale status >/dev/null 2>&1; then tailscale up; fi; elif [ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]; then if ! /Applications/Tailscale.app/Contents/MacOS/Tailscale status >/dev/null 2>&1; then /Applications/Tailscale.app/Contents/MacOS/Tailscale up; fi; else echo -e \"\\n[Warning] Tailscale CLI not found. Please make sure Tailscale is running.\"; fi; TS_IP=$(cat ADGUARD_IP.txt 2>/dev/null); if [ -n \"$TS_IP\" ]; then echo -e \"\\nHijacking DNS to route through AdGuard ($TS_IP). You may be prompted for your Mac password.\"; sudo networksetup -setdnsservers Wi-Fi $TS_IP 2>/dev/null || true; else echo -e \"\\nTip: To automatically hijack DNS, create an 'ADGUARD_IP.txt' file containing only your Tailscale IP.\"; fi; echo -e \"\\nGateway has been STARTED.\"; fi; echo -e \"\\nYou can close this window.\""
end tell
